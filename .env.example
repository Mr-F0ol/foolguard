# Copie este arquivo para .env e ajuste os valores conforme necessário.
# NUNCA comite o arquivo .env real no Git (ele está no .gitignore).

# Banco de dados
DATABASE_URL=postgresql+asyncpg://foolguard:foolguard_dev_password@localhost:5432/foolguard

# Segurança / JWT
# Em produção, gere uma chave forte com: openssl rand -hex 32
SECRET_KEY=troque-esta-chave-em-producao-use-openssl-rand-hex-32
ACCESS_TOKEN_EXPIRE_MINUTES=30
ALGORITHM=HS256

# Fila (Redis) — Mês 2
REDIS_URL=redis://localhost:6379/0

# App
ENVIRONMENT=development
